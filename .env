# kbn/backend/.env
SECRET_KEY=change-me
JWT_SECRET_KEY=jwt-secret-string
DATABASE_URL=oracle+oracledb://system:1000@localhost:1521/?service_name=ORCL
# If your PDB name or service is XEPDB1 or something else, change service_name accordingly:
# DATABASE_URL=oracle+oracledb://system:1000@db-host:1521/?service_name=XEPDB1

# Optional pooling config
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Seed doctor (optional)
SEED_DOCTOR_EMAIL=james.wilson@smarthealthcare.com
SEED_DOCTOR_PW=doc123
